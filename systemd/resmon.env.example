# Copy to /etc/resmon/resmon.env (recommended: chmod 600, owned by root or
# user, since RESMON_MQTT_PASSWORD lives here) and fill in real values.
# Referenced by resmon.service via EnvironmentFile=. CLI flags passed to
# resmon still take precedence over these -- see `resmon --help` or
# include/resmon/constants.hpp for the full flag/env-var mapping.

# --- llama-server ---
RESMON_LLAMA_URL=http://localhost:11434

# --- MQTT broker (TLS, one-sided -- CA cert only, no client cert) ---
RESMON_MQTT_SCHEME=mqtts
RESMON_MQTT_HOST=broker.example.com
# RESMON_MQTT_PORT=8883          # optional; defaults to 8883 for mqtts, 1883 for mqtt
RESMON_CA_CERT=/etc/resmon/ca.pem

# --- Optional: broker username/password, in addition to TLS ---
# RESMON_MQTT_USERNAME=resmon
# RESMON_MQTT_PASSWORD=change-me

# --- Optional: topic/identity overrides ---
# RESMON_TOPIC_PREFIX=resmon
# RESMON_HOSTNAME=localhost
# RESMON_MQTT_CLIENT_ID=resmon-localhost

# --- Optional: sampling interval, in seconds ---
# RESMON_INTERVAL=10
