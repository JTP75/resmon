# Copy to a file (e.g. ~/.resq.env) and fill in values, then source it or set
# RESQ_ENV=path/to/env before running resq. All variables are optional except
# RESMON_MQTT_HOST. CLI flags on resq itself override these.
#
# These share the same RESMON_* names as the publisher (systemd/resmon.env) so
# one env file can serve both sides.

# --- MQTT broker ---
RESMON_MQTT_HOST=localhost
RESMON_MQTT_PORT=8883

# --- TLS (one-sided -- CA cert only, no client cert) ---
RESMON_CA_CERT=.local/mqtt_ca.crt
RESMON_MQTT_TLS_INSECURE=true   # skip hostname/SAN check (needed when connecting by IP or self-signed cert)

# --- Optional: broker username/password, in addition to TLS ---
# RESMON_MQTT_USERNAME=
# RESMON_MQTT_PASSWORD=

# --- Optional: topic/identity overrides ---
# RESMON_TOPIC_PREFIX=resmon
# RESMON_HOSTNAME=<hostname>      # query a specific host; omit to discover all
