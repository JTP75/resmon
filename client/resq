    t = ll.get("throughput", {})
    total = ll.get("totals", {})
    return {
        "predicted_tps": t.get("predicted_tps"),
        "prompt_tps": t.get("prompt_tps"),
        "busy_slots_per_decode": t.get("busy_slots_per_decode"),
